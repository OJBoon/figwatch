# Figma Personal Access Token (https://www.figma.com/developers/api#access-tokens)
FIGMA_PAT=

# Comma-separated Figma file keys to watch
# File key is the part after /design/ in the URL: figma.com/design/<FILE_KEY>/...
FIGMA_FILE_KEYS=

# Poll interval in milliseconds (default: 30000 = 30 seconds)
POLL_INTERVAL=30000

# Default locale for ToV audits: uk, de, fr, nl, benelux
DEFAULT_LOCALE=uk
